<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.WatchCareAI" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/blue_600</item>
        <item name="colorPrimaryVariant">@color/blue_500</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/cyan_600</item>
        <item name="colorSecondaryVariant">@color/cyan_500</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/slate_950</item>
        <item name="colorSurface">@color/slate_900</item>
        <item name="colorOnSurface">@color/white</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/slate_950</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/slate_900</item>
    </style>

    <style name="Theme.WatchCareAI" parent="Base.Theme.WatchCareAI" />
    
    <!-- Button Styles -->
    <style name="ButtonGradient" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/btn_ripple_gradient</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:elevation">8dp</item>
    </style>
    
    <style name="ButtonWhite" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_white_button</item>
        <item name="android:textColor">@color/slate_900</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>
    
    <!-- Input Field Style -->
    <style name="InputFieldGlass" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundMode">none</item>
        <item name="android:textColorHint">@color/slate_400</item>
        <item name="hintTextColor">@color/slate_400</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextTitleLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>
    
    <style name="TextTitleMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>
    
    <style name="TextBody">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/slate_400</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <style name="TextCaption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/slate_400</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>
