<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_light"
    android:backgroundTint="@color/white"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="12dp"
    android:elevation="1dp">

    <!-- Room Number Circle -->
    <TextView
        android:id="@+id/tvRoomNumber"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_icon"
        android:backgroundTint="@color/blue_soft"
        android:text="101"
        android:textSize="12sp"
        android:textColor="@color/blue_primary"
        android:fontFamily="sans-serif-bold"
        android:gravity="center"
        android:layout_marginEnd="16dp" />

    <!-- Patient Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mr. Johnson"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvPatientStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sleeping"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Arrow Icon -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_chevron_right"
        android:tint="@color/text_tertiary" />

</LinearLayout>
