<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Room Number Circle -->
    <TextView
        android:id="@+id/tvRoomNumber"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_icon"
        android:gravity="center"
        android:text="101"
        android:textColor="@color/slate_400"
        android:textSize="12sp"
        android:fontFamily="sans-serif-bold" />

    <!-- Patient Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mr. Johnson"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvPatientStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_sleeping"
            android:textSize="12sp"
            android:textColor="@color/slate_400"
            android:layout_marginTop="2dp"
            android:drawablePadding="4dp"
            android:drawableStart="@android:drawable/ic_menu_view" />
    </LinearLayout>

    <!-- Status Indicator Dot -->
    <View
        android:id="@+id/statusDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/dot_green" />

</LinearLayout>
