<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_secondary">

    <!-- Top Bar with subtle gradient -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_top_bar_gradient"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nurse Greeting with emoji -->
        <TextView
            android:id="@+id/tvNurseGreeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hi 👋 John Doe"
            android:textSize="24sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.01" />

        <!-- Settings Button -->
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_settings"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="Settings"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Alerts Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alerts"
                android:textSize="28sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="16dp" />

            <!-- Active Alert Container -->
            <FrameLayout
                android:id="@+id/alertContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <!-- No Alerts State -->
                <LinearLayout
                    android:id="@+id/noAlertsView"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_no_alerts_gradient"
                    android:padding="32dp"
                    android:elevation="1dp"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="80sp"
                        android:textColor="@color/blue_primary"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Alerts"
                        android:textSize="32sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All systems normal"
                        android:textSize="16sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="12dp" />
                </LinearLayout>

                <!-- Active Alert State -->
                <LinearLayout
                    android:id="@+id/activeAlertView"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_alert_gradient"
                    android:padding="32dp"
                    android:elevation="2dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠"
                        android:textSize="80sp"
                        android:textColor="@color/alert_red"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:id="@+id/tvAlertCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emergency detected"
                        android:textSize="26sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:gravity="center"
                        android:letterSpacing="-0.02"
                        android:layout_marginBottom="28dp" />

                    <Button
                        android:id="@+id/btnAcceptAlert"
                        android:layout_width="200dp"
                        android:layout_height="56dp"
                        android:text="Accept"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.02"
                        android:textAllCaps="false"
                        android:background="@drawable/bg_accept_button"
                        android:elevation="4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Past Alerts Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Past Alerts"
                android:textSize="22sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="16dp" />

            <!-- Past Alerts RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPastAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
