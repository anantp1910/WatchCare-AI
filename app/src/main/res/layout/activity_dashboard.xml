<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nurse Greeting -->
        <TextView
            android:id="@+id/tvNurseGreeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hi, John Doe"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-bold" />

        <!-- Settings Button -->
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Alerts Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alerts"
                android:textSize="32sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="16dp" />

            <!-- Active Alert Container -->
            <FrameLayout
                android:id="@+id/alertContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <!-- No Alerts State (BLUE/CALM) -->
                <LinearLayout
                    android:id="@+id/noAlertsView"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_light"
                    android:backgroundTint="#E3F2FD"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="72sp"
                        android:textColor="@color/blue_primary"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Alerts"
                        android:textSize="32sp"
                        android:textColor="@color/blue_primary"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All systems normal"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Active Alert State (RED/EMERGENCY) -->
                <LinearLayout
                    android:id="@+id/activeAlertView"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_light"
                    android:backgroundTint="#FFEBEE"
                    android:padding="24dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠"
                        android:textSize="72sp"
                        android:textColor="@color/alert_red"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvAlertCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emergency detected"
                        android:textSize="24sp"
                        android:textColor="@color/alert_red"
                        android:fontFamily="sans-serif-bold"
                        android:gravity="center"
                        android:layout_marginBottom="24dp" />

                    <Button
                        android:id="@+id/btnAcceptAlert"
                        android:layout_width="200dp"
                        android:layout_height="60dp"
                        android:text="Accept"
                        android:textSize="20sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-bold"
                        android:background="@drawable/bg_button_primary"
                        android:backgroundTint="@color/alert_red"
                        android:elevation="4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Past Alerts Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Past Alerts"
                android:textSize="24sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold"
                android:layout_marginBottom="16dp" />

            <!-- Past Alerts RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPastAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
